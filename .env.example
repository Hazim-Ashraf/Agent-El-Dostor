# ---- Agent El-Dostor configuration ----
# Copy this file to `.env` and fill in your OpenRouter key. `.env` is git-ignored.

# The ONLY paid dependency. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenRouter is OpenAI-compatible. Change models to any tool-calling model on OpenRouter.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
REASONING_MODEL=openai/gpt-4o-mini
UTILITY_MODEL=openai/gpt-4o-mini

# Postgres + pgvector (matches docker-compose service name `db`).
DATABASE_URL=postgresql://eldostor:eldostor@db:5432/eldostor

# Local embedding model (free, open-source). Runs CPU-only inside Docker on macOS.
#   Lighter/faster dev default : intfloat/multilingual-e5-base   (768-dim)
#   Higher quality (bigger)     : BAAI/bge-m3                     (1024-dim)
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Reranking improves legal precision but costs RAM/CPU. Off by default on 16 GB.
ENABLE_RERANK=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Agent loop bound.
MAX_AGENT_ITERATIONS=6
